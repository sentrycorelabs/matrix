#!/usr/bin/env zsh

IMAGE_NAME="matrix"
CONTAINER_PREFIX="matrix"

usage() {
    echo "Usage: matrix [command] [options]"
    echo ""
    echo "Commands:"
    echo "  (none)       Enter the Matrix in the current directory"
    echo "  build        Build/rebuild the Matrix image"
    echo "  stop [name]  Stop a running container (default: current dir)"
    echo "  list         List running Matrix containers"
    echo "  destroy      Remove the Matrix image"
    echo ""
    echo "Options:"
    echo "  -p PORT      Expose a port (default: 5173)"
    echo "  -n NAME      Custom container name"
}

get_container_name() {
    echo "${CONTAINER_PREFIX}-${1:-$(basename $(pwd))}"
}

cmd_enter() {
    local port=5173
    local name=""

    while [[ $# -gt 0 ]]; do
        case $1 in
            -p) port="$2"; shift 2 ;;
            -n) name="$2"; shift 2 ;;
            *)  shift ;;
        esac
    done

    local container_name=$(get_container_name "$name")

    # Check if container is already running
    if docker ps --format '{{.Names}}' | grep -q "^${container_name}$"; then
        echo "⚡ Reconnecting to ${container_name}..."
        docker exec -it "$container_name" /usr/bin/zsh
        return
    fi

    # Extract Claude Code OAuth token from macOS Keychain
    local oauth_token
    local creds_json
    creds_json=$(security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null || echo "")
    if [[ -n "$creds_json" ]]; then
        oauth_token=$(echo "$creds_json" | python3 -c "import sys,json; print(json.load(sys.stdin)['claudeAiOauth']['accessToken'])" 2>/dev/null || echo "")
    fi

    echo "🟢 Entering the Matrix..."
    docker run --rm -it \
        -v "$(pwd)":/app \
        -v /var/run/docker.sock:/var/run/docker.sock \
        -v "$HOME/.claude":/root/.claude \
        -v "$HOME/.claude.json":/root/.claude.json \
        -p "$port:$port" \
        -e CLAUDE_CODE_OAUTH_TOKEN="${oauth_token:-}" \
        --name "$container_name" \
        "$IMAGE_NAME"
}

cmd_build() {
    echo "🔨 Building the Matrix..."
    docker build -t "$IMAGE_NAME" "$(dirname $0)"
}

cmd_stop() {
    local container_name=$(get_container_name "$1")
    echo "🔴 Exiting the Matrix: ${container_name}..."
    docker stop "$container_name" 2>/dev/null || echo "Container not running."
}

cmd_list() {
    echo "🔵 Active Matrix containers:"
    docker ps --filter "name=${CONTAINER_PREFIX}-" --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"
}

cmd_destroy() {
    echo "💀 Destroying the Matrix image..."
    docker rmi "$IMAGE_NAME" 2>/dev/null || echo "Image not found."
}

case "${1:-}" in
    build)   cmd_build ;;
    stop)    cmd_stop "$2" ;;
    list)    cmd_list ;;
    destroy) cmd_destroy ;;
    help|-h) usage ;;
    *)       cmd_enter "$@" ;;
esac
