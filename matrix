#!/usr/bin/env bash

IMAGE_NAME="matrix"
CONTAINER_PREFIX="matrix"
MATRIX_HOME="$HOME/.matrix"

# ─── Source libraries ────────────────────────────────────────────

source "$MATRIX_HOME/lib/utils.sh"
source "$MATRIX_HOME/lib/config.sh"
source "$MATRIX_HOME/lib/docker.sh"

# ─── Source commands ─────────────────────────────────────────────

for cmd_file in "$MATRIX_HOME/commands/"*.sh; do
    source "$cmd_file"
done

# ─── Usage ───────────────────────────────────────────────────────

usage() {
    echo "Usage: matrix [command] [options]"
    echo ""
    echo "Commands:"
    echo "  (none)       Enter the Matrix in the current directory"
    echo "  build        Build/rebuild the Matrix image"
    echo "  stop [name]  Stop a running container (default: current dir)"
    echo "  list         List running Matrix containers"
    echo "  destroy      Remove the Matrix image"
    echo "  config       Re-run setup for the current directory"
    echo "  update       Pull latest and rebuild the image"
    echo ""
    echo "Options:"
    echo "  -p PORTS     Expose ports, comma-separated (default: random)"
    echo "  -n NAME      Custom container name"
}

# ─── Dispatch ────────────────────────────────────────────────────

case "${1:-}" in
    build)   cmd_build ;;
    stop)    cmd_stop "$2" ;;
    list)    cmd_list ;;
    destroy) cmd_destroy ;;
    config)  run_setup ;;
    update)  cmd_update ;;
    help|-h) usage ;;
    *)       cmd_enter "$@" ;;
esac
